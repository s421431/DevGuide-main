{
  "name": "devguide",
  "displayName": "DevGuide",
  "description": "AI-powered in-editor mentor",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devguide.openPanel",
        "title": "DevGuide: Open Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devguide-sidebar",
          "title": "DevGuide",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "devguide-sidebar": [
        {
          "type": "webview",
          "id": "devguide.panel",
          "name": "DevGuide Mentor"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.105.3",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.893.0"
  }
}
